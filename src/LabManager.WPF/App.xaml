<Application x:Class="LabManager.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LabManager.WPF"
             xmlns:vm="clr-namespace:LabManager.WPF.ViewModels"
             xmlns:views="clr-namespace:LabManager.WPF.Views"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- DataTemplates to map ViewModels to Views -->
        <DataTemplate DataType="{x:Type vm:LabsViewModel}">
            <views:LabsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PatientsViewModel}">
            <views:PatientsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TestOrdersViewModel}">
            <views:TestOrdersView />
        </DataTemplate>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A5568"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
