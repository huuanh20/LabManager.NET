<Window x:Class="LabManager.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:LabManager.WPF.ViewModels"
        mc:Ignorable="d"
        Title="LabManager - Laboratory Management System" Height="600" Width="1000">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <DockPanel>
        <!-- Navigation Sidebar -->
        <StackPanel DockPanel.Dock="Left" Width="180" Background="#2D3748">
            <TextBlock Text="LabManager" Foreground="White" FontSize="18" FontWeight="Bold"
                       Margin="12,16,12,24" TextWrapping="Wrap"/>
            <Button Content="🔬  Labs" Command="{Binding NavigateToLabsCommand}"
                    Style="{StaticResource NavButtonStyle}" Margin="8,4"/>
            <Button Content="👤  Patients" Command="{Binding NavigateToPatientsCommand}"
                    Style="{StaticResource NavButtonStyle}" Margin="8,4"/>
            <Button Content="📋  Test Orders" Command="{Binding NavigateToTestOrdersCommand}"
                    Style="{StaticResource NavButtonStyle}" Margin="8,4"/>
        </StackPanel>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="#EDF2F7">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" />
            </StatusBarItem>
        </StatusBar>

        <!-- Main Content Area -->
        <ContentControl Content="{Binding CurrentView}" Margin="16"/>
    </DockPanel>
</Window>
